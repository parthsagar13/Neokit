# Production API URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Google OAuth client ID (Web application — same as server GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Template slug used by landing page Buy Now (must exist in MongoDB)
NEXT_PUBLIC_NEOKIT_PRODUCT_SLUG=neokit-starter-kit
