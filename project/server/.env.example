PORT=5000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/codemarket?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production

SUPABASE_URL=https://your-project.supabase.co
# Use project root URL only — do NOT append /rest/v1/
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=templates

# Public API URL used for preview links (no trailing slash)
# Local: http://localhost:5000
# Vercel: https://your-project.vercel.app
API_PUBLIC_URL=http://localhost:5000

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Frontend URL for password reset links and CORS
# Local: http://localhost:5173
# Production: https://your-site.netlify.app
CLIENT_URL=http://localhost:5173

# Google OAuth (required for Google Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# SPA popup flow uses postmessage; use your production URL for redirect-based flows
GOOGLE_CALLBACK_URL=postmessage

# Landing page Buy Now product (must match a Template.slug in MongoDB)
NEOKIT_PRODUCT_SLUG=neokit-starter-kit
